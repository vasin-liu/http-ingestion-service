# HTTP Ingestion Service packaged runtime configuration
# Copy this file to conf/service.env and customize for your environment.
#
# All paths may be absolute or relative to the package root (parent of bin/).

# --- Java runtime (JDK 21 required) ---
# HI_JAVA_HOME=E:/Home/vasin.GENSOKYO/sdk/zulu-jdk21.0.9
# HI_JAVA_MIN_VERSION=21

# --- Service identity ---
HI_SERVICE_NAME=http-ingestion-service

# --- Network ---
HI_SERVER_PORT=8080
# Override full health URL (default: http://127.0.0.1:${HI_SERVER_PORT}/actuator/health)
# HI_HEALTH_URL=http://127.0.0.1:8080/actuator/health

# --- Storage ---
# H2 metadata database directory (maps to Spring META_DB_PATH)
# HI_META_DB_PATH=../data
# HI_DATA_DIR=../data

# --- External PostgreSQL sink (optional) ---
# EXTERNAL_PG_URL=jdbc:postgresql://localhost:5432/ingest
# EXTERNAL_PG_USER=ingest
# EXTERNAL_PG_PASSWORD=changeme

# --- External Kafka sink (optional, Wave 4) ---
# EXTERNAL_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Spring Boot ---
# HI_SPRING_PROFILES_ACTIVE=
# Extra args appended to the java command (space-separated)
# HI_SPRING_ARGS=

# --- JVM (daemon / background mode) ---
HI_HEAP_MIN=512m
HI_HEAP_MAX=1g
# Extra JVM flags (e.g. -Dfile.encoding=UTF-8)
# HI_JVM_OPTS=

# --- Logging & paths ---
# HI_LOG_DIR=../logs
# HI_LOG_FILE=../logs/http-ingestion-service.log
# HI_PID_FILE=../http-ingestion-service.pid
# HI_JVMDUMP_DIR=../jvmdump

# --- Process control ---
# Seconds to wait after background start before returning
HI_START_WAIT_SEC=30
# Graceful stop timeout before SIGKILL
HI_STOP_TIMEOUT_SEC=60
# 1 = background (default), 0 = foreground
# HI_DAEMON=1
# Allow interactive JDK path prompt on TTY (not for systemd/cron)
# HI_JAVA_PROMPT=0
