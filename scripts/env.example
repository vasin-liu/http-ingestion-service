# HTTP Ingestion Service — 环境变量模板（本地开发）
# 复制为 scripts/env 后按需修改
# 打包部署请使用 conf/service.env（见 http-ingestion-boot/src/main/resources/service.env.example）

# --- 服务 ---
SERVER_PORT=8080
SERVER_HOST=127.0.0.1

# --- Java ---
JAVA_HOME=E:/Home/vasin.GENSOKYO/sdk/zulu-jdk21.0.9
JAVA_OPTS=-Xms512m -Xmx1024m

# --- 路径 ---
META_DB_PATH=./data

# --- 业务 Sink（外部 PostgreSQL，可选）---
# EXTERNAL_PG_URL=jdbc:postgresql://localhost:5432/ingest
# EXTERNAL_PG_USER=ingest
# EXTERNAL_PG_PASSWORD=changeme

# --- 启停 ---
START_TIMEOUT=120
STOP_TIMEOUT=60
HEALTH_PATH=/actuator/health

# --- 进程控制 ---
# HI_DAEMON=1
# HI_FOREGROUND=1
